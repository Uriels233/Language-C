#include<stdio.h>
#include <string.h>
int main () {
    float height, imcWoman, imcMan;
    char gender [20];

    printf("\nPlease, type your height: ");
    scanf("%f", &height);
    printf("\nPlease, type your gender [Female] [Male]: ");
    scanf("%s", &gender);

    if (strcmp(gender, "Female")== 0) {
         imcWoman = ((62.1 * height)-44.7);
         printf("Your IMC is: %.2f", imcWoman);
    } else if (strcmp(gender, "Male")== 0) {
        imcMan = ((72.7*height)-58);
        printf("Your IMC is: %.2f", imcMan);
    } else {
        printf("Command not found");
    }








    return 0;
}
